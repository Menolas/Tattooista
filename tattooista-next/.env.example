# Database (PostgreSQL)
# For local development, use: postgresql://user:password@localhost:5432/tattooista
# For production, use your database provider's connection string
DATABASE_URL="postgresql://user:password@localhost:5432/tattooista"

# NextAuth.js
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Uploadthing (File uploads)
# Get your keys from: https://uploadthing.com/dashboard
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# Resend (Email)
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=""

# Email Configuration
FROM_EMAIL="Tattooista <noreply@yourdomain.com>"
ADMIN_EMAIL="admin@yourdomain.com"

# Public URL (used in emails and redirects)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
